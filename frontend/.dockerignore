# --- Dependencies ---
# Prevents architecture mismatch issues (e.g., native binaries compiled for Mac/Windows) 
# by forcing the container to resolve and install its own Linux-compatible Node modules.
node_modules/

# --- Next.js Build Artifacts & Caches ---
# Prevents local builds and SWC caches from overriding or bloating the containerized build process.
.next/
out/
build/
dist/
.vercel/
.turbo/

# --- Security & Credentials ---
# Strict exclusion of all environment files to prevent sensitive API keys from leaking into image layers.
.env
.env.*
*.pem

# --- Package Manager Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE & OS Metadata ---
.vscode/
.idea/
.DS_Store
Thumbs.db